rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, role (admin/member), displayName, createdAt
    //
    // Collection: analytics
    // Fields: platform, reach, engagement, spend, conversions, timestamp
    //
    // Collection: competitors
    // Fields: competitorName, adStrategy, topKeywords, lastUpdated
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == 'team@ekshakti.org' && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'member'];
    }

    function isValidSavedAd(data) {
      return data.keys().hasAll(['headline', 'platform', 'uid', 'savedAt']) &&
             data.headline is string &&
             data.platform is string &&
             data.uid is string &&
             data.savedAt is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin()) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /competitors/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /campaigns/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /saved_ads/{id} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSavedAd(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }
  }
}
